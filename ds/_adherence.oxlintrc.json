{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/feedback/**",
              "components/icons/**",
              "components/site/**",
              "ui_kits/kaylee-portfolio/**",
              "ui_kits/rock-paper-scissors/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Blackout Sunrise|Blackout Midnight|Blackout Two Am|ChunkFive|League Spartan|Work Sans))/i]",
        "message": "Font not provided by the design system. Available: Blackout Sunrise, Blackout Midnight, Blackout Two Am, ChunkFive, League Spartan, Work Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|label|tone|selected|dimmed|width|height|key|ref|className|style|children)$/]",
        "message": "<ChoiceCard> doesn't accept that prop. Declared props: image, label, tone, selected, dimmed, width, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|yellow|green|red)$/]",
        "message": "<ChoiceCard> tone must be one of 'blue' | 'yellow' | 'green' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|multiline|rows|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, required, multiline, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='GestureGlow'] > JSXAttribute > JSXIdentifier[name!=/^(?:gesture|size|animate|key|ref|className|style|children)$/]",
        "message": "<GestureGlow> doesn't accept that prop. Declared props: gesture, size, animate."
      },
      {
        "selector": "JSXOpeningElement[name.name='GestureGlow'] > JSXAttribute[name.name='gesture'] > Literal[value!=/^(?:tap|double|triple)$/]",
        "message": "<GestureGlow> gesture must be one of 'tap' | 'double' | 'triple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pills'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|size|state|icon|leadingIcon|disabled|key|ref|className|style|children)$/]",
        "message": "<Pills> doesn't accept that prop. Declared props: label, size, state, icon, leadingIcon, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pills'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Pills> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pills'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:primary|secondary|tertiary)$/]",
        "message": "<Pills> state must be one of 'primary' | 'secondary' | 'tertiary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pills'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:none|left|dropdown)$/]",
        "message": "<Pills> icon must be one of 'none' | 'left' | 'dropdown'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:disabled|key|ref|className|style|children)$/]",
        "message": "<SiteButton> doesn't accept that prop. Declared props: disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThemeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:dark|onToggle|size|key|ref|className|style|children)$/]",
        "message": "<ThemeToggle> doesn't accept that prop. Declared props: dark, onToggle, size."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
